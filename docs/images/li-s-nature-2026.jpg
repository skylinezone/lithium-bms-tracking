    <meta name="journal_id" content="43246"/>
    <meta name="dc.title" content="Sulfur cathodes for next-generation batteries"/>
    <meta name="dc.source" content="Communications Materials 2026 7:1"/>
    <meta name="dc.format" content="text/html"/>
    <meta name="dc.publisher" content="Nature Publishing Group"/>
